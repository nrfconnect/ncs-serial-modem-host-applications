menu "Main"

config APP_SYNC_INTERVAL
	int "Sync interval (seconds)"
	default 600
	help
	  Period between cloud syncs. One timer in the main state machine drives both
	  the location fix and the battery report each cycle.

config APP_SYNC_BOOT_DELAY_SECONDS
	int "Delay before the first sync after connect (seconds)"
	default 5

config APP_MAIN_WATCHDOG_TIMEOUT_SECONDS
	int "Watchdog timeout"
	default 300

config APP_MAIN_MSG_PROCESSING_TIMEOUT_SECONDS
	int "Maximum message processing time"
	default 290

module = APP_MAIN
module-str = Main
source "subsys/logging/Kconfig.template.log_config"

endmenu
